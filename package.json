{
  "name": "recall-speaking-trainer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n app,server \"npm:dev:app\" \"npm:dev:server\"",
    "dev:app": "vite",
    "dev:server": "tsx watch server/index.ts",
    "server": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "fastify": "^5.6.1",
    "microsoft-cognitiveservices-speech-sdk": "^1.47.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "concurrently": "^9.2.1",
    "jsdom": "^27.2.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "tsx": "^4.20.6",
    "vite": "^8.0.12",
    "vitest": "^4.0.8"
  }
}
